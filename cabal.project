packages: .
write-ghc-environment-files: always
split-sections: True

-- duckdb-ffi's configure runs a test-link for -lduckdb before tv-hask's
-- stanza is consulted. Top-level extra-lib-dirs in cabal.project only
-- applies to local packages, so target deps explicitly. `package *`
-- covers both duckdb-ffi (needs vendor/duckdb) and tv-hask itself
-- (needs vendor/lib for libprqlc_c.a).
package *
  extra-lib-dirs:
    vendor/duckdb
    vendor/lib
