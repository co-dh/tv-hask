packages: .
write-ghc-environment-files: always
split-sections: True

-- duckdb-ffi's configure runs a test-link for -lduckdb before tv-hask's
-- executable stanza is consulted. Relative paths in `package *` are
-- resolved against each package's unpacked source dir (not the project
-- root), so the vendor dirs must be passed as absolute paths on the
-- cabal CLI via --extra-lib-dirs (see CI and CONTRIBUTING notes).
