[0.0, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\u001b[?25l\u001b(B\u001b[m\u001b[H\u001b[2J\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[1;1H tag     \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m val#\u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u001b[2;1H         \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[38;5;2m\u2588    \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[38;5;16;48;5;15m\u001b[3;1H a-b-c   \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[48;5;234m  10 \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[4;1H d-e-f   \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[4;13H20\u001b(B\u001b[m\u001b[38;5;240m\u001b[4;16H\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[5;1H g-h     \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[5;13H30\u001b(B\u001b[m\u001b[38;5;240m\u001b[5;16H\u2502\u001b(B\u001b[m\u001b[48;5;238m\u001b[6;1H x-y-z-w \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[6;13H40\u001b(B\u001b[m\u001b[38;5;240m\u001b[6;16H\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;16;48;5;15m\u001b[22;1H tag     \u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[1m\u001b[4m\u001b[38;5;2;48;5;60m val#\u001b(B\u001b[m\u001b[38;5;240m\u2502\u001b(B\u001b[m\u001b[38;5;7;48;5;4m\u001b[23;1H[split_test.csv]                                                                \u001b(B\u001b[m\u001b[38;5;6m\u001b[24;1Htag                       \u001b(B\u001b[m\u001b[38;5;8m#4\u001b(B\u001b[m\u001b[38;5;6m                               c0/2 grp=0 sel=0 r0/4"]
